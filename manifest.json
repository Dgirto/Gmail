{
  "id": "gmail",
  "name": "Gmail",
  "version": "1.0.0",
  "description": "Lectura y envío de correos en Gmail (cuenta personal o Google Workspace) mediante OAuth2 con refresh token",
  "icon": "icon.svg",
  "category": "messaging",
  "library": {
    "package": "ruvic-gmail-connector",
    "install": "pip install git+https://github.com/Dgirto/Gmail.git#subdirectory=lib",
    "import_name": "ruvic_gmail_connector"
  },
  "auth_modes": [
    {
      "id": "oauth2_platform",
      "label": "Autorizar con Google (recomendado)",
      "fields": [
        {
          "key": "refresh_token",
          "label": "Autorización de la cuenta",
          "type": "oauth2_authorization",
          "secret": true,
          "required": true,
          "oauth2": {
            "authorization_url": "https://accounts.google.com/o/oauth2/v2/auth",
            "token_url": "https://oauth2.googleapis.com/token",
            "scopes": [
              "https://www.googleapis.com/auth/gmail.readonly",
              "https://www.googleapis.com/auth/gmail.send",
              "openid",
              "email"
            ],
            "extra_authorize_params": {
              "access_type": "offline",
              "prompt": "consent"
            },
            "pkce": true,
            "capture": "refresh_token",
            "identity_hint": "id_token.email",
            "client_credentials": "platform",
            "platform_provider": "google"
          },
          "help_text": "Guarda la instancia y pulsa Autorizar. Usa la app OAuth de Ruvic (RUVIC_OAUTH_GOOGLE_CLIENT_ID / RUVIC_OAUTH_GOOGLE_CLIENT_SECRET)."
        },
        {
          "key": "request_timeout",
          "label": "Timeout de solicitud (segundos)",
          "type": "number",
          "required": false,
          "default": "30"
        }
      ]
    },
    {
      "id": "oauth2",
      "label": "Usar credenciales propias",
      "fields": [
        {
          "key": "client_id",
          "label": "Client ID de OAuth",
          "type": "text",
          "required": true,
          "placeholder": "1234567890-abc123.apps.googleusercontent.com",
          "help_text": "ID del cliente OAuth (tipo 'Aplicación web') creado en Google Cloud Console. Registra como URI de redirección: {WEB_URL}/api/v1/connectors/oauth/callback"
        },
        {
          "key": "client_secret",
          "label": "Client Secret de OAuth",
          "type": "password",
          "secret": true,
          "required": true,
          "help_text": "Secreto del mismo cliente OAuth"
        },
        {
          "key": "refresh_token",
          "label": "Autorización de la cuenta",
          "type": "oauth2_authorization",
          "secret": true,
          "required": true,
          "oauth2": {
            "authorization_url": "https://accounts.google.com/o/oauth2/v2/auth",
            "token_url": "https://oauth2.googleapis.com/token",
            "scopes": [
              "https://www.googleapis.com/auth/gmail.readonly",
              "https://www.googleapis.com/auth/gmail.send",
              "openid",
              "email"
            ],
            "extra_authorize_params": {
              "access_type": "offline",
              "prompt": "consent"
            },
            "pkce": true,
            "capture": "refresh_token",
            "identity_hint": "id_token.email",
            "client_credentials": "user"
          },
          "help_text": "Guarda la instancia con Client ID y Client Secret, luego pulsa Autorizar."
        },
        {
          "key": "request_timeout",
          "label": "Timeout de solicitud (segundos)",
          "type": "number",
          "required": false,
          "default": "30"
        }
      ]
    },
    {
      "id": "manual",
      "label": "Refresh token manual",
      "fields": [
        {
          "key": "client_id",
          "label": "Client ID de OAuth",
          "type": "text",
          "required": true,
          "placeholder": "1234567890-abc123.apps.googleusercontent.com",
          "help_text": "ID del cliente OAuth creado en Google Cloud Console"
        },
        {
          "key": "client_secret",
          "label": "Client Secret de OAuth",
          "type": "password",
          "secret": true,
          "required": true,
          "help_text": "Secreto del mismo cliente OAuth"
        },
        {
          "key": "refresh_token",
          "label": "Refresh token",
          "type": "password",
          "secret": true,
          "required": true,
          "help_text": "Obtenido una sola vez con get_refresh_token.py o pegando un token existente"
        },
        {
          "key": "request_timeout",
          "label": "Timeout de solicitud (segundos)",
          "type": "number",
          "required": false,
          "default": "30"
        }
      ]
    }
  ],
  "env_prefix": "RUVIC_GMAIL_",
  "operations": ["mail.list", "mail.read", "mail.send", "mail.send_with_attachment"],
  "test_connection": true,
  "docs": {
    "skill": "SKILL.md",
    "permissions_note": "OAuth2 con scopes gmail.readonly y gmail.send. Modo recomendado: Autorizar con Google (app OAuth de Ruvic). Alternativas: credenciales propias o refresh token manual. Funciona con cuentas Gmail personales y Google Workspace."
  }
}